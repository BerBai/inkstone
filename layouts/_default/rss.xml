{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>{{ with .Site.Params.description }}{{ . }}{{ else }}Recent content on {{ $.Site.Title }}{{ end }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.Locale | default .Site.Language.Lang | replaceRE "_" "-" | lower }}</language>
    {{- with .Site.Params.author }}
    <managingEditor>{{ . }}</managingEditor>
    {{- end }}
    <copyright>© {{ now.Format "2006" }} {{ .Site.Params.author }}</copyright>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml"/>
    {{- range first 20 (where .Site.RegularPages "Section" "posts") }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <description>{{ printf "<![CDATA[%s]]>" (cond (ne .Description "") .Description (.Summary | plainify)) | safeHTML }}</description>
      <content:encoded>{{ printf "<![CDATA[%s]]>" (.Content | string) | safeHTML }}</content:encoded>
    </item>
    {{- end }}
  </channel>
</rss>
